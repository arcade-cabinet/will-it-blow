{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/.expo",
      "!!**/.worktrees",
      "!!**/.claude/worktrees",
      "!!**/playwright",
      "!!**/public",
      "!!**/android",
      "!!**/ios",
      "!!**/docs/api",
      "!!**/*.css",
      "!!**/coverage",
      "!!**/vendor",
      "!!**/test-results",
      "!!**/playwright-report",
      "!!**/.playwright-mcp",
      "!!**/docs/poc",
      "!!sausage_factory.html"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": false
    }
  },
  "css": {
    "parser": {
      "cssModules": true
    },
    "linter": {
      "enabled": false
    },
    "formatter": {
      "enabled": false
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useAriaPropsSupportedByRole": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      }
    }
  }
}
