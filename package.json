{
  "name": "will-it-blow",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:browser:unit": "vitest run --project browser tests/unit",
    "test:browser:micro": "vitest run --project browser tests/micro",
    "test:browser:meso": "vitest run --project browser tests/meso",
    "test:browser:macro": "vitest run --project browser tests/macro",
    "test:browser:harness": "vitest run --project browser tests/harness",
    "test:browser:src": "vitest run --project browser src",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "report:browser": "tsx scripts/generate-test-report.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "cap:ios": "cap sync ios && cap open ios",
    "cap:android": "cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/postprocessing": "^3.0.0",
    "@react-three/rapier": "^2.0.0",
    "@use-gesture/react": "^10.0.0",
    "drizzle-orm": "^0.45.1",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.5",
    "postprocessing": "^6.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "suspend-react": "^0.1.3",
    "three": "^0.172.0",
    "tone": "^15.0.0",
    "yuka": "^0.7.8",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@capacitor-community/sqlite": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "^3.2.4",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vitest-browser-react": "^1.0.1"
  }
}
