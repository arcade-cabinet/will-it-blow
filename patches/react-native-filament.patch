+void ViewWrapper::setFogOptions(std::unordered_map<std::string, double> options) {
+  if (options.empty()) return;
+  std::unique_lock lock(_mutex);
+  filament::FogOptions fog = pointee()->getFogOptions();
+  if (auto it = options.find("enabled"); it != options.end()) fog.enabled = it->second > 0.5;
+  if (auto it = options.find("distance"); it != options.end()) fog.distance = static_cast<float>(it->second);
+  if (auto it = options.find("maximumOpacity"); it != options.end()) fog.maximumOpacity = static_cast<float>(it->second);
+  if (auto it = options.find("height"); it != options.end()) fog.height = static_cast<float>(it->second);
+  if (auto it = options.find("heightFalloff"); it != options.end()) fog.heightFalloff = static_cast<float>(it->second);
+  if (auto it = options.find("fogColorFromIbl"); it != options.end()) fog.fogColorFromIbl = it->second > 0.5;
+  if (auto it = options.find("colorR"); it != options.end()) fog.color.r = static_cast<float>(it->second);
+  if (auto it = options.find("colorG"); it != options.end()) fog.color.g = static_cast<float>(it->second);
+  if (auto it = options.find("colorB"); it != options.end()) fog.color.b = static_cast<float>(it->second);
+  pointee()->setFogOptions(fog);
+}
+
 } // namespace margelo
