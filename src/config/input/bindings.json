{
  "$schema": "Input binding configuration for all supported platforms",
  "movement": {
    "forward": {
      "keyboard": ["w", "ArrowUp"],
      "gamepad": { "axis": "leftStick.y", "invert": true, "deadzone": 0.15 },
      "touch": { "source": "leftJoystick", "axis": "y" },
      "xr": {
        "hand": "left",
        "component": "xr-standard-thumbstick",
        "axis": "y",
        "invert": true,
        "deadzone": 0.15
      }
    },
    "backward": {
      "keyboard": ["s", "ArrowDown"],
      "gamepad": { "axis": "leftStick.y", "deadzone": 0.15 },
      "touch": { "source": "leftJoystick", "axis": "-y" },
      "xr": { "hand": "left", "component": "xr-standard-thumbstick", "axis": "y", "deadzone": 0.15 }
    },
    "strafeLeft": {
      "keyboard": ["a", "ArrowLeft"],
      "gamepad": { "axis": "leftStick.x", "invert": true, "deadzone": 0.15 },
      "touch": { "source": "leftJoystick", "axis": "-x" },
      "xr": {
        "hand": "left",
        "component": "xr-standard-thumbstick",
        "axis": "x",
        "invert": true,
        "deadzone": 0.15
      }
    },
    "strafeRight": {
      "keyboard": ["d", "ArrowRight"],
      "gamepad": { "axis": "leftStick.x", "deadzone": 0.15 },
      "touch": { "source": "leftJoystick", "axis": "x" },
      "xr": { "hand": "left", "component": "xr-standard-thumbstick", "axis": "x", "deadzone": 0.15 }
    }
  },
  "look": {
    "yaw": {
      "keyboard": { "source": "pointerLock", "axis": "movementX", "sensitivity": 0.002 },
      "gamepad": { "axis": "rightStick.x", "sensitivity": 2.5, "deadzone": 0.1 },
      "touch": { "source": "rightDrag", "axis": "dx", "sensitivity": 0.004 },
      "xr": {
        "hand": "right",
        "component": "xr-standard-thumbstick",
        "axis": "x",
        "sensitivity": 2.0,
        "deadzone": 0.15
      }
    },
    "pitch": {
      "keyboard": { "source": "pointerLock", "axis": "movementY", "sensitivity": 0.002 },
      "gamepad": { "axis": "rightStick.y", "sensitivity": 2.0, "deadzone": 0.1, "invert": false },
      "touch": { "source": "rightDrag", "axis": "dy", "sensitivity": 0.004 },
      "xr": {
        "hand": "right",
        "component": "xr-standard-thumbstick",
        "axis": "y",
        "sensitivity": 1.5,
        "deadzone": 0.15
      }
    }
  },
  "actions": {
    "interact": {
      "keyboard": ["e", " "],
      "gamepad": { "button": "a" },
      "touch": { "gesture": "tap" },
      "xr": { "hand": "right", "component": "a-button" }
    },
    "pause": {
      "keyboard": ["Escape"],
      "gamepad": { "button": "start" },
      "touch": { "gesture": "menuButton" },
      "xr": { "hand": "right", "component": "b-button" }
    },
    "flip": {
      "keyboard": ["f"],
      "gamepad": { "button": "y" },
      "touch": { "gesture": "swipeUp" },
      "xr": { "hand": "right", "component": "y-button" }
    },
    "grab": {
      "keyboard": ["g"],
      "gamepad": { "button": "rt" },
      "touch": { "gesture": "longPress" },
      "xr": { "hand": "right", "component": "xr-standard-trigger" }
    },
    "press": {
      "keyboard": ["q"],
      "gamepad": { "button": "rb" },
      "touch": { "gesture": "twoFingerTap" },
      "xr": { "hand": "right", "component": "xr-standard-squeeze" }
    }
  },
  "tuning": {
    "walkSpeed": 3.0,
    "pitchLimit": 80,
    "eyeHeight": 1.6,
    "wallMargin": 0.5,
    "positionSyncHz": 10
  }
}
